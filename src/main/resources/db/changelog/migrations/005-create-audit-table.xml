<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260214-01" author="Gem">
        <createTable tableName="audit_logs">
            <!-- Поля из BaseEntity -->
            <column name="uuid" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="company_uuid" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="version" type="BIGINT" defaultValue="0"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="now()"/>

            <!-- Специфичные поля аудита -->
            <column name="clutch_uuid" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="action" type="VARCHAR(32)">
                <constraints nullable="false"/>
            </column>
            <column name="old_values" type="JSONB"/>
            <column name="new_values" type="JSONB"/>
            <column name="changed_by" type="VARCHAR(255)"/>
        </createTable>

        <!-- Индекс для быстрого поиска истории конкретной записи -->
        <createIndex tableName="audit_logs" indexName="idx_audit_clutch_lookup">
            <column name="clutch_uuid"/>
            <column name="created_at"/>
        </createIndex>

        <!-- Индекс для фильтрации по компании (Multi-tenancy) -->
        <createIndex tableName="audit_logs" indexName="idx_audit_company_uuid">
            <column name="company_uuid"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
